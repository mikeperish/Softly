<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Softly — Antistress & Focus</title>
    <meta name="description" content="A pocket antistress companion for ADHD & anxiety. Interactive fidgets with haptic feedback, ambient sounds, and a gentle Pomodoro timer.">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=DM+Mono:wght@400;500&family=Inter:wght@400;500;600&family=Syne:wght@600;700;800&display=swap" rel="stylesheet">
    <style>
        *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

        :root {
            --bg: #0D1422;
            --surface: rgba(18, 28, 45, 0.7);
            --border: #1E2D45;
            --teal: #00D4B4;
            --purple: #9B6DFF;
            --pink: #FF6B9D;
            --amber: #F59E0B;
            --red: #EF4444;
            --text: #E2E8F0;
            --text-dim: #7B8BA5;
            --text-muted: #4A5568;
        }

        body {
            font-family: 'Inter', sans-serif;
            background: var(--bg);
            color: var(--text);
            overflow-x: hidden;
            -webkit-font-smoothing: antialiased;
        }

        /* Decorative blobs */
        .blob-container {
            position: fixed;
            top: 0; left: 0; right: 0; bottom: 0;
            pointer-events: none;
            z-index: 0;
            overflow: hidden;
        }

        .blob {
            position: absolute;
            border-radius: 50%;
            filter: blur(120px);
            opacity: 0.12;
        }

        .blob-1 {
            width: 600px; height: 600px;
            background: var(--teal);
            top: -200px; right: -100px;
            animation: float1 20s ease-in-out infinite;
        }

        .blob-2 {
            width: 500px; height: 500px;
            background: var(--purple);
            top: 300px; left: -200px;
            animation: float2 25s ease-in-out infinite;
        }

        .blob-3 {
            width: 400px; height: 400px;
            background: var(--pink);
            bottom: 200px; right: -100px;
            opacity: 0.08;
            animation: float3 22s ease-in-out infinite;
        }

        @keyframes float1 {
            0%, 100% { transform: translate(0, 0); }
            50% { transform: translate(-60px, 40px); }
        }
        @keyframes float2 {
            0%, 100% { transform: translate(0, 0); }
            50% { transform: translate(40px, -30px); }
        }
        @keyframes float3 {
            0%, 100% { transform: translate(0, 0); }
            50% { transform: translate(-30px, -50px); }
        }

        .content {
            position: relative;
            z-index: 1;
            max-width: 960px;
            margin: 0 auto;
            padding: 0 24px;
        }

        /* NAV */
        nav {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 28px 0;
            border-bottom: 1px solid rgba(30, 45, 69, 0.5);
        }

        .logo {
            font-family: 'Syne', sans-serif;
            font-weight: 700;
            font-size: 22px;
            color: var(--text);
            letter-spacing: -0.5px;
        }

        .logo span {
            color: var(--teal);
        }

        nav a {
            font-family: 'DM Mono', monospace;
            font-size: 13px;
            color: var(--text-dim);
            text-decoration: none;
            transition: color 0.2s;
        }

        nav a:hover { color: var(--teal); }

        .nav-links {
            display: flex;
            gap: 28px;
            align-items: center;
        }

        /* HERO */
        .hero {
            text-align: center;
            padding: 100px 0 80px;
        }

        .hero-badge {
            display: inline-block;
            font-family: 'DM Mono', monospace;
            font-size: 12px;
            color: var(--teal);
            background: rgba(0, 212, 180, 0.08);
            border: 1px solid rgba(0, 212, 180, 0.2);
            border-radius: 100px;
            padding: 6px 16px;
            margin-bottom: 32px;
            letter-spacing: 0.5px;
        }

        h1 {
            font-family: 'Syne', sans-serif;
            font-weight: 800;
            font-size: clamp(42px, 7vw, 72px);
            line-height: 1.05;
            letter-spacing: -2px;
            margin-bottom: 24px;
        }

        h1 .gradient-text {
            background: linear-gradient(135deg, var(--teal), var(--purple));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .hero-sub {
            font-size: 18px;
            color: var(--text-dim);
            max-width: 520px;
            margin: 0 auto 48px;
            line-height: 1.7;
        }

        .hero-cta {
            display: inline-flex;
            align-items: center;
            gap: 10px;
            background: var(--teal);
            color: var(--bg);
            font-family: 'Syne', sans-serif;
            font-weight: 700;
            font-size: 16px;
            padding: 16px 36px;
            border-radius: 14px;
            text-decoration: none;
            transition: all 0.3s ease;
            box-shadow: 0 0 40px rgba(0, 212, 180, 0.15);
        }

        .hero-cta:hover {
            transform: translateY(-2px);
            box-shadow: 0 0 60px rgba(0, 212, 180, 0.25);
        }

        .hero-cta svg {
            width: 20px; height: 20px;
        }

        /* FEATURES */
        .features-section {
            padding: 40px 0 80px;
        }

        .section-label {
            font-family: 'DM Mono', monospace;
            font-size: 12px;
            color: var(--text-muted);
            letter-spacing: 2px;
            text-transform: uppercase;
            margin-bottom: 12px;
        }

        h2 {
            font-family: 'Syne', sans-serif;
            font-weight: 700;
            font-size: 36px;
            letter-spacing: -1px;
            margin-bottom: 48px;
        }

        .features-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 16px;
        }

        .feature-card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: 16px;
            padding: 32px 28px;
            transition: all 0.3s ease;
            position: relative;
            overflow: hidden;
        }

        .feature-card::before {
            content: '';
            position: absolute;
            top: 0; left: 0; right: 0;
            height: 2px;
            background: var(--card-accent);
            opacity: 0;
            transition: opacity 0.3s;
        }

        .feature-card:hover::before { opacity: 1; }
        .feature-card:hover {
            border-color: rgba(255,255,255,0.08);
            transform: translateY(-2px);
        }

        .feature-icon {
            width: 44px; height: 44px;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 20px;
            margin-bottom: 20px;
        }

        .feature-card h3 {
            font-family: 'Syne', sans-serif;
            font-weight: 700;
            font-size: 20px;
            margin-bottom: 10px;
            letter-spacing: -0.3px;
        }

        .feature-card p {
            font-size: 14px;
            color: var(--text-dim);
            line-height: 1.7;
        }

        .card-pop { --card-accent: #FF6B9D; }
        .card-pop .feature-icon { background: rgba(255, 107, 157, 0.12); }
        .card-sound { --card-accent: #4ECDC4; }
        .card-sound .feature-icon { background: rgba(78, 205, 196, 0.12); }
        .card-cube { --card-accent: #9B6DFF; }
        .card-cube .feature-icon { background: rgba(155, 109, 255, 0.12); }
        .card-focus { --card-accent: #EF4444; }
        .card-focus .feature-icon { background: rgba(239, 68, 68, 0.12); }
        .card-physics { --card-accent: #00D4B4; }
        .card-physics .feature-icon { background: rgba(0, 212, 180, 0.12); }

        /* STATS */
        .stats-bar {
            display: flex;
            justify-content: center;
            gap: 60px;
            padding: 48px 0;
            border-top: 1px solid var(--border);
            border-bottom: 1px solid var(--border);
            margin: 20px 0 80px;
            flex-wrap: wrap;
        }

        .stat-item {
            text-align: center;
        }

        .stat-value {
            font-family: 'DM Mono', monospace;
            font-size: 32px;
            font-weight: 500;
            color: var(--teal);
            margin-bottom: 4px;
        }

        .stat-label {
            font-size: 13px;
            color: var(--text-muted);
        }

        /* WHY */
        .why-section {
            padding: 0 0 80px;
        }

        .why-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
            gap: 20px;
        }

        .why-item {
            display: flex;
            gap: 16px;
            align-items: flex-start;
            padding: 24px;
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: 14px;
        }

        .why-icon {
            font-size: 18px;
            flex-shrink: 0;
            width: 36px; height: 36px;
            display: flex;
            align-items: center;
            justify-content: center;
            background: rgba(0, 212, 180, 0.08);
            border-radius: 10px;
        }

        .why-item h4 {
            font-family: 'Syne', sans-serif;
            font-weight: 600;
            font-size: 15px;
            margin-bottom: 4px;
        }

        .why-item p {
            font-size: 13px;
            color: var(--text-dim);
            line-height: 1.6;
        }

        /* ADHD BANNER */
        .adhd-banner {
            background: linear-gradient(135deg, rgba(0, 212, 180, 0.06), rgba(155, 109, 255, 0.06));
            border: 1px solid rgba(0, 212, 180, 0.15);
            border-radius: 20px;
            padding: 48px 40px;
            text-align: center;
            margin-bottom: 80px;
        }

        .adhd-banner h2 {
            margin-bottom: 16px;
            font-size: 30px;
        }

        .adhd-banner p {
            color: var(--text-dim);
            font-size: 16px;
            line-height: 1.7;
            max-width: 560px;
            margin: 0 auto;
        }

        /* FOOTER */
        footer {
            border-top: 1px solid var(--border);
            padding: 40px 0;
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 20px;
        }

        .footer-left {
            font-family: 'DM Mono', monospace;
            font-size: 12px;
            color: var(--text-muted);
        }

        .footer-links {
            display: flex;
            gap: 24px;
        }

        .footer-links a {
            font-family: 'DM Mono', monospace;
            font-size: 12px;
            color: var(--text-dim);
            text-decoration: none;
            transition: color 0.2s;
        }

        .footer-links a:hover { color: var(--teal); }

        /* ANIMATIONS */
        .fade-up {
            opacity: 0;
            transform: translateY(30px);
            transition: all 0.6s cubic-bezier(0.16, 1, 0.3, 1);
        }

        .fade-up.visible {
            opacity: 1;
            transform: translateY(0);
        }

        /* MOBILE */
        @media (max-width: 640px) {
            .hero { padding: 60px 0 50px; }
            h1 { letter-spacing: -1px; }
            .hero-sub { font-size: 16px; }
            .stats-bar { gap: 32px; }
            .stat-value { font-size: 26px; }
            .adhd-banner { padding: 32px 24px; }
            .nav-links { gap: 16px; }
            footer { flex-direction: column; text-align: center; }
        }
    </style>
</head>
<body>

<div class="blob-container">
    <div class="blob blob-1"></div>
    <div class="blob blob-2"></div>
    <div class="blob blob-3"></div>
</div>

<div class="content">

    <!-- NAV -->
    <nav>
        <div class="logo">softly<span>.</span></div>
        <div class="nav-links">
            <a href="#features">Features</a>
            <a href="https://mikeperish.github.io/Softly/privacy.html">Privacy</a>
            <a href="https://mikeperish.github.io/Softly/terms.html">Terms</a>
            <a href="#support">Support</a>
        </div>
    </nav>

    <!-- HERO -->
    <section class="hero fade-up">
        <div class="hero-badge">iOS · Free to download</div>
        <h1>Your mind<br>deserves to<br><span class="gradient-text">feel softly</span></h1>
        <p class="hero-sub">Interactive fidgets with haptic feedback, ambient sounds, and a gentle Pomodoro timer — designed for ADHD & anxiety relief.</p>
        <a href="https://apps.apple.com/app/id6761616188" class="hero-cta">
            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/></svg>
            Download on App Store
        </a>
    </section>

    <!-- FEATURES -->
    <section class="features-section fade-up" id="features">
        <p class="section-label">Features</p>
        <h2>Five ways to decompress</h2>

        <div class="features-grid">
            <div class="feature-card card-pop">
                <div class="feature-icon">🫧</div>
                <h3>Pop</h3>
                <p>Pixel-art bubble wrap with satisfying pops and haptics. Three silhouettes to discover — pop them all and a new one appears.</p>
            </div>
            <div class="feature-card card-sound">
                <div class="feature-icon">🎵</div>
                <h3>Sound</h3>
                <p>Shape ambient noise with your finger. White, Brown, and Grey noise with real-time control. Ripple effects follow every touch.</p>
            </div>
            <div class="feature-card card-cube">
                <div class="feature-icon">🧊</div>
                <h3>Cube</h3>
                <p>An infinite digital fidget cube. Swipe 16 tiles in any direction — smooth 3D flips with satisfying click sounds.</p>
            </div>
            <div class="feature-card card-focus">
                <div class="feature-icon">⏱</div>
                <h3>Focus</h3>
                <p>Pomodoro timer built for ADHD. Standard and short modes. Tracks streaks and sessions. Fidget while you focus.</p>
            </div>
            <div class="feature-card card-physics">
                <div class="feature-icon">🌀</div>
                <h3>Physics</h3>
                <p>A spinning top driven by your gyroscope. Swipe to spin, tilt to roll. Mesmerizing patterns with realistic physics.</p>
            </div>
        </div>
    </section>

    <!-- STATS -->
    <div class="stats-bar fade-up">
        <div class="stat-item">
            <div class="stat-value">5</div>
            <div class="stat-label">Interactive fidgets</div>
        </div>
        <div class="stat-item">
            <div class="stat-value">60fps</div>
            <div class="stat-label">Smooth animations</div>
        </div>
        <div class="stat-item">
            <div class="stat-value">0</div>
            <div class="stat-label">Ads & distractions</div>
        </div>
        <div class="stat-item">
            <div class="stat-value">∞</div>
            <div class="stat-label">Haptic moments</div>
        </div>
    </div>

    <!-- WHY -->
    <section class="why-section fade-up">
        <p class="section-label">Why Softly</p>
        <h2>Built for restless minds</h2>

        <div class="why-grid">
            <div class="why-item">
                <div class="why-icon">📳</div>
                <div>
                    <h4>Instant haptics</h4>
                    <p>Every tap, swipe, and spin triggers precise haptic feedback. Your fingers feel what your eyes see.</p>
                </div>
            </div>
            <div class="why-item">
                <div class="why-icon">🌙</div>
                <div>
                    <h4>Dark & soothing</h4>
                    <p>Deep dark theme designed for low-light use. No harsh colors, no visual noise — just calm.</p>
                </div>
            </div>
            <div class="why-item">
                <div class="why-icon">🎧</div>
                <div>
                    <h4>Background sound</h4>
                    <p>Ambient noise keeps playing while you use other tabs. Focus timer + sound = the perfect combo.</p>
                </div>
            </div>
            <div class="why-item">
                <div class="why-icon">✨</div>
                <div>
                    <h4>No clutter</h4>
                    <p>Minimal UI with zero pop-ups, no tutorials, no interruptions. Just open and start fidgeting.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- ADHD BANNER -->
    <div class="adhd-banner fade-up">
        <h2>Made for ADHD minds</h2>
        <p>We know the struggle — racing thoughts, restless energy, difficulty focusing. Softly gives your hands something to do while your brain does its thing. No pressure, no timers you can't pause, no guilt.</p>
    </div>

    <!-- SUPPORT -->
    <section class="why-section fade-up" id="support">
        <p class="section-label">Support</p>
        <h2>Need help?</h2>

        <div class="why-grid">
            <div class="why-item">
                <div class="why-icon">✉️</div>
                <div>
                    <h4>Email us</h4>
                    <p>Have a question or found a bug? Write to <a href="mailto:mykhailo.mirzaiev@icloud.com" style="color: var(--teal); text-decoration: none;">mykhailo.mirzaiev@icloud.com</a></p>
                </div>
            </div>
            <div class="why-item">
                <div class="why-icon">⚡</div>
                <div>
                    <h4>Response time</h4>
                    <p>We typically respond within 24 hours. Your feedback helps us make Softly better for everyone.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- FOOTER -->
    <footer>
        <div class="footer-left">© 2026 Mykhailo Mirzaiev</div>
        <div class="footer-links">
            <a href="https://mikeperish.github.io/Softly/privacy.html">Privacy Policy</a>
            <a href="https://mikeperish.github.io/Softly/terms.html">Terms of Use</a>
            <a href="#support">Support</a>
        </div>
    </footer>

</div>

<script>
    // Intersection Observer for fade-up animations
    const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
            if (entry.isIntersecting) {
                entry.target.classList.add('visible');
            }
        });
    }, { threshold: 0.1 });

    document.querySelectorAll('.fade-up').forEach(el => observer.observe(el));
</script>

</body>
</html>
